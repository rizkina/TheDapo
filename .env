APP_NAME="The Dapo"
APP_ENV=production
APP_KEY=base64:x54rFvs6Mu/C0VAyLIBMsSSKi19+Q6GWIIeuWzFjIZQ=
APP_DEBUG=false
APP_URL=http://172.21.1.249:8000  # WAJIB gunakan domain asli & HTTPS

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# Log harian agar file log tidak membengkak dalam satu file besar
LOG_CHANNEL=daily
LOG_LEVEL=error

# DATABASE (Gunakan password kuat!)
DB_CONNECTION=pgsql
DB_HOST=db # ganti dengan postgreqsl server anda
DB_PORT=5432
DB_DATABASE=db_dapo_prod # ganti dengan nama database anda
DB_USERNAME=postgres  # ganti dengan user postgresql anda
DB_PASSWORD=GunakanPasswordYangSangatKuat123! # ganti dengan password anda

# REDIS (Optimasi Sesi & Antrean)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true 
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD= # IsiJikaRedisMenggunakanPassword
REDIS_PORT=6379

# FILESYSTEM & PATH BINARY
FILESYSTEM_DISK=public
PG_DUMP_PATH=/usr/bin/pg_dump # Sesuaikan lokasi bin postgres
PSQL_PATH=/usr/bin/psql       # Sesuaikan lokasi bin postgres

# EMAIL (Untuk produksi ganti ke SMTP jika ingin kirim email beneran)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@thedapo.sch.id"
MAIL_FROM_NAME="${APP_NAME}"

# GOOGLE DRIVE (Tersimpan di DB, ini hanya cadangan)
GOOGLE_DRIVE_FOLDER_ID=

VITE_APP_NAME="${APP_NAME}"
